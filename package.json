{
  "name": "@jr200-labs/xstate-nats",
  "version": "0.6.0",
  "description": "XState machine for NATS",
  "license": "MIT",
  "author": "Jayshan Raghunandan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jr200-labs/xstate-nats.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "prettier": "prettier --write \"**/*.{ts,mjs,js,json,md,yml,yaml}\"",
    "lint": "tsc --noEmit",
    "prepare": "husky",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "xstate",
    "nats",
    "state-machine",
    "websocket"
  ],
  "dependencies": {
    "@nats-io/jetstream": "^3.3.1",
    "@nats-io/kv": "^3.3.1",
    "@nats-io/nats-core": "^3.3.1",
    "@nats-io/obj": "^3.3.1",
    "xstate": "^5.30.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.3",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
