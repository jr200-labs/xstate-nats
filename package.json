{
  "name": "@jr200-labs/xstate-nats",
  "version": "0.8.0",
  "description": "XState machine for NATS",
  "license": "MIT",
  "author": "Jayshan Raghunandan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jr200-labs/xstate-nats.git"
  },
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "prettier": "prettier --write \"**/*.{ts,mjs,js,json,md,yml,yaml}\"",
    "lint": "tsc --noEmit && eslint \"src/**/*.{ts,tsx}\"",
    "prepare": "husky",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "xstate",
    "nats",
    "state-machine",
    "websocket"
  ],
  "dependencies": {
    "@nats-io/jetstream": "^3.3.1",
    "@nats-io/kv": "^3.3.1",
    "@nats-io/nats-core": "^3.3.1",
    "@nats-io/obj": "^3.3.1",
    "xstate": "^5.31.0"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.7.1",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "syncpack": "^15.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
